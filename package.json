{
  "name": "aegis",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Aegis — enterprise access control for a multi-tenant microservices SaaS platform",
  "scripts": {
    "build": "nx run-many -t build --all",
    "build:affected": "nx affected -t build",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "serve": "nx serve",
    "migrate": "ts-node apps/cli/src/main.ts migrate",
    "migrate:seed": "ts-node apps/cli/src/main.ts migrate-seeders",
    "migrate:status": "ts-node apps/cli/src/main.ts show-migrations",
    "start:api": "node dist/apps/${SERVICE_NAME}/main.js",
    "start:worker": "node dist/apps/${SERVICE_NAME}/worker.js",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "dev:pm2": "npm run build && pm2 start ecosystem.config.js && pm2 logs",
    "dev:pm2:stop": "pm2 delete ecosystem.config.js"
  },
  "devDependencies": {
    "@nx/eslint": "^19.0.0",
    "@nx/jest": "^19.0.0",
    "@nx/js": "^19.0.0",
    "@nx/node": "^19.0.0",
    "@nx/webpack": "^19.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.24",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nx": "^19.0.0",
    "prettier": "^3.2.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "bullmq": "^5.7.0",
    "casbin": "^5.30.0",
    "casbin-pg-adapter": "^1.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "inversify": "^6.0.2",
    "inversify-binding-decorators": "^4.0.0",
    "inversify-express-utils": "^6.4.6",
    "ioredis": "^5.4.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "kafkajs": "^2.2.4",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.0",
    "pino": "^9.0.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.0",
    "umzug": "^3.8.0",
    "uuid": "^9.0.1"
  }
}
