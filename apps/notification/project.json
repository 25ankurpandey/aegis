{
  "name": "notification",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/notification/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/notification",
        "main": "apps/notification/src/index.ts",
        "tsConfig": "apps/notification/tsconfig.app.json",
        "webpackConfig": "apps/notification/webpack.config.js"
      },
      "configurations": {
        "production": { "optimization": false, "outputHashing": "none" }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": { "buildTarget": "notification:build" }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": { "jestConfig": "apps/notification/jest.config.ts" }
    },
    "lint": { "executor": "@nx/eslint:lint" }
  },
  "tags": ["scope:app", "service:notification"]
}
