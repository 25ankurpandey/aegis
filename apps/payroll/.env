# apps/payroll/.env — committed dummy values; consistent across services so docker compose works with zero manual setup.
NODE_ENV=development
AEGIS_ENV=local
PROCESS_TYPE=api
SERVICE_NAME=payroll
PORT=4003
LOG_LEVEL=debug

# Postgres (runtime app role = NON-OWNER so RLS is enforced). Hostname = compose service name.
DATABASE_URL=postgres://aegis_app:aegis_app_pw@postgres:5432/aegis
DB_POOL_MAX=10

# Redis (cache only)
REDIS_URL=redis://redis:6379

# Kafka — event-bus transport (KRaft single broker); hostname = compose service name.
KAFKA_BROKERS=kafka:9092

# Auth (dummy local secrets — overridden by param store in real envs)
AUTH_JWT_SECRET=dev-only-user-token-secret-change-me
JWKS_URL=http://user-management:4001/.well-known/jwks.json
TOKEN_TTL_SECONDS=900

# Service-to-service (signed internal token + origin gate)
INTERNAL_JWT_SECRET=dev-only-internal-s2s-secret-change-me
INTERNAL_ORIGIN=aegis-internal
SOURCE_SERVICE=payroll

# Internal service URLs (docker network hostnames)
GATEWAY_URL=http://gateway:4000
USER_MANAGEMENT_URL=http://user-management:4001
EXPENSE_URL=http://expense:4002
PAYROLL_URL=http://payroll:4003
REPORTING_URL=http://reporting:4004
WORKFLOW_URL=http://workflow:4005
NOTIFICATION_URL=http://notification:4006
INVOICE_URL=http://invoice:4007

# Field-level encryption (payroll sensitive fields) — dummy 32-byte key
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
